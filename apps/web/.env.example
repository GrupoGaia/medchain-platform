# Supabase — obter em supabase.com/dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Supabase service role — NUNCA expor no frontend, usar apenas no servidor
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# URL base da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — obter em supabase.com/dashboard > Project Settings > Database > Connection string (Transaction mode para serverless)
DATABASE_URL=postgresql://postgres.SEU_PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.SEU_PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
