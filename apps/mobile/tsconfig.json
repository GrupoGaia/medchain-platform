{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@medchain/api-contract": ["../../packages/api-contract/src/index.ts"],
      "@medchain/domain": ["../../packages/domain/src/index.ts"],
      "@medchain/ui-tokens": ["../../packages/ui-tokens/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts", "expo-env.d.ts"],
  "exclude": ["node_modules"]
}
