# Supabase — obter em supabase.com/dashboard > Project Settings > API
# No Expo, variáveis públicas DEVEM ter prefixo EXPO_PUBLIC_
EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# URL da API web (portal Next.js rodando em dev)
# Em celular físico com Expo Go, use o IP local da máquina, não localhost.
EXPO_PUBLIC_API_URL=http://SEU_IP_LOCAL:3000
